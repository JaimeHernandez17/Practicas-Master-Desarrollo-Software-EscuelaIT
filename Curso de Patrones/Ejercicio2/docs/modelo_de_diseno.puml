        # {abstract} applyLocalDiscounts(ticket: Ticket): void
        # {abstract} formatReceipt(ticket: Ticket): String
        # {abstract} notifyLocalSystems(ticket: Ticket): void
    }

    class SpainTicketProcessor {
        # validateCart(cart: Cart): boolean
        # applyLocalTaxes(ticket: Ticket): void
        # applyLocalDiscounts(ticket: Ticket): void
        # formatReceipt(ticket: Ticket): String
        # notifyLocalSystems(ticket: Ticket): void
    }

    class FranceTicketProcessor {
        # validateCart(cart: Cart): boolean
        # applyLocalTaxes(ticket: Ticket): void
        # applyLocalDiscounts(ticket: Ticket): void
        # formatReceipt(ticket: Ticket): String
        # notifyLocalSystems(ticket: Ticket): void
    }

    class USATicketProcessor {
        - stateTaxCalculator: StateTaxCalculator
        # validateCart(cart: Cart): boolean
        # applyLocalTaxes(ticket: Ticket): void
        # applyLocalDiscounts(ticket: Ticket): void
        # formatReceipt(ticket: Ticket): String
        # notifyLocalSystems(ticket: Ticket): void
    }

    TicketProcessor <|-- SpainTicketProcessor
    TicketProcessor <|-- FranceTicketProcessor
    TicketProcessor <|-- USATicketProcessor
}

' =====================================================
' Relaciones entre patrones
' =====================================================
CountryFactory ..> TicketBuilder : creates
CountryFactory ..> TaxStrategy : creates
CountryFactory ..> DiscountStrategy : creates
CountryFactory ..> CurrencyFormatter : creates

AbstractTicketBuilder --> TaxStrategy : uses
AbstractTicketBuilder --> DiscountStrategy : uses
AbstractTicketBuilder --> TicketComponent : creates

TotalCalculatorVisitor --> TaxStrategy : uses
PrinterVisitor --> CurrencyFormatter : uses
DiscountApplierVisitor --> DiscountStrategy : uses

TicketCommand --> Ticket : modifies
AddLineCommand --> TicketLine : adds

TicketProcessor --> CountryFactory : uses

@enduml

