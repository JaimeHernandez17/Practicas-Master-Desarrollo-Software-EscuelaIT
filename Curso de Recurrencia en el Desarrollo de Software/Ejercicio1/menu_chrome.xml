        <etiqueta>Adelante</etiqueta>
      </item>
      <item id="recargar">
        <etiqueta>Recargar</etiqueta>
      </item>
      <separador/>
      <item id="guardar-como">
        <etiqueta>Guardar como...</etiqueta>
      </item>
      <item id="imprimir">
        <etiqueta>Imprimir...</etiqueta>
      </item>
      <separador/>
      <item id="inspeccionar">
        <etiqueta>Inspeccionar</etiqueta>
      </item>
    </opciones>
